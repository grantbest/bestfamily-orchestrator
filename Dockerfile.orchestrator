FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Agent Orchestrator dependencies
RUN pip install --no-cache-dir \
    temporalio \
    ollama \
    httpx \
    fastapi \
    uvicorn \
    python-multipart \
    google-genai \
    google-generativeai \
    pydantic \
    aider-chat \
    openai \
    anthropic

# Context is root of the workspace
COPY BestFam-Orchestrator /app/BestFam-Orchestrator/
COPY Homelab /app/Homelab
COPY BettingApp /app/BettingApp

# Set PYTHONPATH to include all components
ENV PYTHONPATH="/app/BestFam-Orchestrator:/app/BestFam-Orchestrator/src:/app/Homelab/scripts:/app/BettingApp/scripts"

# Default command: Start the Unified Orchestrator
CMD ["python", "-u", "BestFam-Orchestrator/src/workers/unified_orchestrator.py"]
